NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:8088

POSTGRES_DB=streamgate
POSTGRES_USER=streamgate
POSTGRES_PASSWORD=streamgate_dev_password
DATABASE_URL=postgresql://streamgate:streamgate_dev_password@postgres:5432/streamgate?schema=public

REDIS_URL=redis://redis:6379

BACKEND_PORT=3000
ADMIN_PORT=8080
TVHEADEND_CONNECTOR_PORT=3100
PROXY_PORT=8088

DEVICE_TOKEN_SECRET=replace-with-long-random-secret
ADMIN_JWT_SECRET=replace-with-long-random-secret

MOCK_MODE=true
TVHEADEND_BASE_URL=http://tvheadend:9981
TVHEADEND_USERNAME=replace-me
TVHEADEND_PASSWORD=replace-me
TVHEADEND_DEFAULT_PROFILE=pass

STREAM_TRANSCODE_MODE=streamgate
TVHEADEND_HD_PROFILE=prd-matroska_h264_transcode
TVHEADEND_SD_PROFILE=prd-matroska_h264_transcode_sd
TVHEADEND_PROFILE_MIME_TYPE=video/x-matroska
TVHEADEND_HD_MIME_TYPE=video/x-matroska
TVHEADEND_SD_MIME_TYPE=video/x-matroska

FFMPEG_TRANSCODER=vaapi
FFMPEG_LOG_LEVEL=warning
VAAPI_DEVICE=/dev/dri/renderD128
VAAPI_RENDER_DEVICE=/dev/dri/renderD128
HD_VIDEO_BITRATE=5500k
HD_VIDEO_MAXRATE=7000k
HD_VIDEO_BUFSIZE=11000k
SD_VIDEO_BITRATE=1400k
SD_VIDEO_MAXRATE=1800k
SD_VIDEO_BUFSIZE=2800k
SD_AUDIO_BITRATE=128k

VITE_API_BASE_URL=http://localhost:3000
ANDROID_API_BASE_URL=http://10.0.2.2:3000
